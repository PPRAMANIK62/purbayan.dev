{
  "name": "portfolio-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "bun --filter web dev",
    "dev:vault": "bun --filter vault dev",
    "build:web": "bun --filter web build",
    "build:vault": "bun --filter vault build",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc,css,md}": [
      "oxfmt"
    ]
  }
}
